{
  "name": "node-reliability-lab",
  "version": "0.1.0",
  "description": "Production-minded Node.js runtime patterns for backpressure, worker isolation, async context, cancellation, observability, and graceful shutdown",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wasiliy-strecker/node-reliability-lab.git"
  },
  "bugs": {
    "url": "https://github.com/wasiliy-strecker/node-reliability-lab/issues"
  },
  "homepage": "https://github.com/wasiliy-strecker/node-reliability-lab#readme",
  "keywords": [
    "nodejs",
    "typescript",
    "backpressure",
    "worker-threads",
    "async-local-storage",
    "graceful-shutdown"
  ],
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=22.15.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "pnpm build && node --enable-source-maps --watch dist/src/app/main.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "scenario": "pnpm build && node --enable-source-maps dist/src/scenarios/run.js",
    "scenario:smoke": "node --enable-source-maps dist/src/scenarios/run.js --smoke",
    "start": "node --enable-source-maps dist/src/app/main.js",
    "test": "pnpm build && node --enable-source-maps --test --test-reporter=spec dist/test/*.test.js",
    "test:coverage": "c8 --reporter=text --reporter=lcov --check-coverage --lines=80 --functions=80 --branches=70 --statements=80 node --enable-source-maps --test dist/test/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm build && pnpm test:coverage && pnpm scenario:smoke"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.19.15",
    "c8": "^10.1.3",
    "eslint": "^9.39.2",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0"
  }
}
